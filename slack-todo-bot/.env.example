# Hermes Slack TODO bot -- environment variables reference
#
# Copy to ~/.hermes/.env and fill in real values. Never commit the real
# ~/.hermes/.env to git -- this example file uses placeholders only.
#
# After editing:
#   chmod 600 ~/.hermes/.env
#   hermes gateway restart

# ---- Required: Slack Socket Mode credentials ----

# Bot token (xoxb-...) from Slack App -> Settings -> Install App (or
# OAuth & Permissions -> Install to Workspace).
SLACK_BOT_TOKEN=xoxb-REPLACE-WITH-YOUR-BOT-TOKEN

# App-Level token (xapp-...) from Slack App -> Settings -> Basic Information
# -> App-Level Tokens. MUST include the `connections:write` scope, or Socket
# Mode cannot connect (apps.connections.open returns missing_scope).
SLACK_APP_TOKEN=xapp-1-REPLACE-WITH-YOUR-APP-TOKEN

# ---- Required: authorization ----

# Comma-separated Slack Member IDs allowed to talk to the bot.
# Deny-by-default: anyone not listed is refused. Find yours in Slack by
# clicking your name -> ... (more) -> Copy Member ID (starts with U).
SLACK_ALLOWED_USERS=U0YOURMEMBERID

# ---- Required: delivery target ----

# Where cron output (hourly summary, 9 AM digest) is posted. For a private
# "GitHub App bot" experience, point this at the 1:1 DM channel between you
# and the bot (starts with D). Find it via:
#   curl -s -X POST https://slack.com/api/conversations.open \
#     -H "Authorization: Bearer $SLACK_BOT_TOKEN" \
#     -H "Content-Type: application/json; charset=utf-8" \
#     -d '{"users":"U0YOURMEMBERID"}' | python3 -m json.tool
# -> channel.id is your D... DM channel.
SLACK_HOME_CHANNEL=D0YOURDMCHANNELID
SLACK_HOME_CHANNEL_NAME=hermes_bot

# ---- Required: task file location ----

# Directory the 9 AM `today` digest reads Markdown task files from.
TODAY_DIR=~/tasks

# ---- Optional: hourly scan tuning ----

# Comma-separated channel IDs the hourly scan should read. Defaults to
# SLACK_HOME_CHANNEL if unset. The bot must be invited to each channel
# (via /invite @hermes_bot) or conversations.history returns no messages.
# SLACK_WATCH_CHANNELS=C0AAAAAAAA,C0BBBBBBBB

# On the first run (no saved state), read this many minutes back. Default 60.
# SLACK_LOOKBACK_MINS=60

# ---- Optional: Jira digest (hourly, priority integration) ----

# Your Jira Cloud site, no trailing slash.
# JIRA_BASE_URL=https://REPLACE-WITH-YOUR-SITE.atlassian.net

# Atlassian account email (the one you log into Jira with).
# JIRA_EMAIL=REPLACE-WITH-YOUR-EMAIL@example.com

# API token: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_API_TOKEN=REPLACE-WITH-YOUR-JIRA-API-TOKEN

# Base JQL filter (the "updated since last run" clause is applied automatically
# on top of this -- do not add your own time filter here).
# Default: assignee = currentUser() AND statusCategory != Done ORDER BY updated DESC
# JIRA_JQL=assignee = currentUser() AND statusCategory != Done ORDER BY updated DESC

# On the first run (no saved state), treat issues updated within this many
# minutes as new. Default 1440 (24h) -- Jira tickets move slower than Slack.
# JIRA_LOOKBACK_MINS=1440

# Max issues fetched per run. Default 50.
# JIRA_MAX_RESULTS=50

# ---- Optional: GitHub digest (hourly) ----

# Personal access token. Classic PAT needs the `repo` scope (or `public_repo`
# for public-only); fine-grained tokens need Issues:read + Pull requests:read
# on every repo you want covered.
# Create at: https://github.com/settings/tokens
# GITHUB_TOKEN=REPLACE-WITH-YOUR-GITHUB-TOKEN

# On the first run (no saved state), treat items updated within this many
# minutes as new. Default 60.
# GITHUB_LOOKBACK_MINS=60

# Max items fetched per query (assigned + review-requested are separate
# queries). Default 50.
# GITHUB_MAX_RESULTS=50

# ---- Optional: further lockdown (in ~/.hermes/config.yaml, not .env) ----
#
# slack:
#   allowed_channels:
#     - "D0YOURDMCHANNELID"      # your DM only; everything else dropped
#   unauthorized_dm_behavior: "ignore"   # no pairing flow; unknown DMers dropped
